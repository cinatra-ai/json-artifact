{
  "name": "@cinatra-ai/json-artifact",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "files": [
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node scripts/test.mjs"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "artifact",
    "displayName": "JSON",
    "vendor": {
      "key": "cinatra-ai",
      "name": "Cinatra"
    },
    "dependencies": [],
    "artifact": {
      "accepts": {
        "file": {
          "mimeTypes": [
            "application/json"
          ]
        }
      },
      "ui": {
        "abiVersion": 1,
        "sdkAbiRange": "^2.4.0",
        "renderers": {
          "detail": {
            "entry": "./src/renderers/detail.tsx",
            "propsApiVersion": 1,
            "representations": [
              "application/json"
            ]
          },
          "preview": {
            "entry": "./src/renderers/preview.tsx",
            "propsApiVersion": 1,
            "representations": [
              "application/json"
            ]
          }
        }
      }
    }
  }
}
